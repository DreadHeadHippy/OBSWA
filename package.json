{
  "name": "com.dreadheadhippy.obswa",
  "version": "0.1.0",
  "description": "OBS automation workflows for Stream Deck",
  "main": "dist/plugin.js",
  "type": "module",
  "scripts": {
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "build": "rollup --config rollup.config.mjs",
    "watch": "rollup --config rollup.config.mjs --watch",
    "lint": "eslint src --ext .ts",
    "icons": "node scripts/generate-icons.js",
    "install:dev": "npm run build && npx streamdeck link com.dreadheadhippy.obswa.sdPlugin",
    "validate": "npx streamdeck validate com.dreadheadhippy.obswa.sdPlugin",
    "package": "npm run build && node scripts/package.js"
  },
  "keywords": [
    "streamdeck",
    "obs",
    "automation",
    "workflow"
  ],
  "author": "DreadHeadHippy",
  "license": "MIT",
  "dependencies": {
    "@elgato/streamdeck": "^2.0.4",
    "obs-websocket-js": "^5.0.8"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "rollup": "^4.59.1",
    "tslib": "^2.8.1",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
